model TimeSlot {
  id String @id @default(uuid())

  pitchId String
  pitch   Pitch  @relation(fields: [pitchId], references: [id])

  date DateTime

  startTime String
  endTime   String

  isBooked Boolean @default(false)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  bookings     Booking[]
  reservations Reservation[]
}
